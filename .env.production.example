# Production frontend environment — placeholders only.
# Copy values into the Cloudflare build environment (or a local .env.production that is never committed).
# Never put secrets in VITE_ variables (they are embedded into the browser bundle at build time).
# Changing VITE_API_BASE_URL requires a new frontend build and deployment.

VITE_API_BASE_URL=https://api.example.com/api/v1
VITE_APP_NAME=ThyroCare AI
VITE_APP_ENV=production
