# ThyroCare AI API Ś copy to `.env` for local overrides.
# Never commit real secrets.

APP_NAME=ThyroCare AI API
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=thyrocare_ai
MONGODB_SERVER_SELECTION_TIMEOUT_MS=3000
MONGODB_CONNECT_TIMEOUT_MS=3000
MONGODB_SOCKET_TIMEOUT_MS=10000
DATABASE_AUTO_INITIALIZE=true
DATABASE_RUN_MIGRATIONS=true
DATABASE_REQUIRE_CONNECTION=false
DATABASE_TEST_NAME=thyrocare_ai_test
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEFAULT=100/minute
OPENAPI_ENABLED=true

# Authentication (Phase 6)
AUTHENTICATION_ENABLED=true
JWT_SECRET_KEY=replace-with-a-long-random-production-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=thyrocare-ai-api
JWT_AUDIENCE=thyrocare-ai-web
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_CLOCK_SKEW_SECONDS=30
PASSWORD_MIN_LENGTH=10
PASSWORD_MAX_LENGTH=128
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
AUTH_RATE_LIMIT_LOGIN=10/minute
AUTH_RATE_LIMIT_REGISTER=5/minute
AUTH_RATE_LIMIT_REFRESH=30/minute
REFRESH_COOKIE_NAME=thyrocare_refresh
CSRF_COOKIE_NAME=thyrocare_csrf
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/api/v1/auth
CSRF_HEADER_NAME=X-CSRF-Token
REQUIRE_EMAIL_VERIFICATION=false

# Production guidance:
# APP_ENVIRONMENT=production
# DEBUG=false
# COOKIE_SECURE=true
# JWT_SECRET_KEY=<openssl rand -hex 32>
# DATABASE_AUTO_INITIALIZE=false
# DATABASE_RUN_MIGRATIONS=false
# DATABASE_REQUIRE_CONNECTION=true
# OPENAPI_ENABLED=false

# Phase 13A Ś email delivery / account recovery / Google (defaults disabled)
EMAIL_DELIVERY_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ThyroCare AI
FRONTEND_PUBLIC_URL=http://localhost:5173

EMAIL_VERIFICATION_ENABLED=false
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

PASSWORD_RESET_ENABLED=false
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=

AUTH_RATE_LIMIT_FORGOT_PASSWORD=5/minute
AUTH_RATE_LIMIT_RESET_PASSWORD=10/minute
AUTH_RATE_LIMIT_VERIFY_EMAIL=20/minute
AUTH_RATE_LIMIT_RESEND_VERIFICATION=3/minute
AUTH_RATE_LIMIT_CHANGE_PASSWORD=5/minute
AUTH_RATE_LIMIT_GOOGLE=10/minute

# Phase 11 Ś Safe educational assistant (default disabled)
AI_ASSISTANT_ENABLED=false
LLM_PROVIDER=disabled
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=20
LLM_MAX_OUTPUT_TOKENS=512
KNOWLEDGE_RETRIEVAL_MODE=lexical
KNOWLEDGE_MAX_CHUNKS=5
KNOWLEDGE_MIN_SCORE=0.15
CHAT_MAX_MESSAGE_LENGTH=4000
CHAT_MAX_HISTORY_MESSAGES=50
CHAT_RATE_LIMIT=20/minute
